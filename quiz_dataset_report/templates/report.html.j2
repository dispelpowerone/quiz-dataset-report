<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ report.app_name }} — quiz issue report</title>
<style>
  body { font-family: -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
         color: #1f2937; margin: 0; padding: 24px; background: #f3f4f6; }
  .wrap { max-width: 860px; margin: 0 auto; }
  h1 { font-size: 20px; margin: 0 0 4px; }
  .meta { color: #6b7280; font-size: 13px; margin-bottom: 20px; }
  .summary { background: #fff; border: 1px solid #e5e7eb; border-radius: 8px;
             padding: 14px 18px; margin-bottom: 20px; }
  .summary b { font-size: 18px; }
  .q { background: #fff; border: 1px solid #e5e7eb; border-radius: 8px;
       padding: 16px 18px; margin-bottom: 14px; }
  .q-head { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; }
  .q-title { font-size: 15px; font-weight: 600; margin: 0; }
  .q-test { color: #6b7280; font-size: 12px; }
  .badge { background: #ef4444; color: #fff; border-radius: 12px; padding: 2px 10px;
           font-size: 13px; font-weight: 600; white-space: nowrap; }
  .badge.reset { background: #6b7280; margin-left: 6px; }
  .q-text { margin: 8px 0 10px; font-size: 14px; }
  .unresolved .q-text { color: #b45309; font-style: italic; }
  img.q-img { max-width: 220px; max-height: 160px; border: 1px solid #e5e7eb;
              border-radius: 6px; margin: 4px 0 10px; display: block; }
  .img-name { color: #6b7280; font-size: 12px; }
  ul.answers { margin: 6px 0 12px; padding-left: 20px; font-size: 13px; }
  ul.answers li.right { color: #047857; font-weight: 600; }
  table { border-collapse: collapse; width: 100%; font-size: 13px; }
  th, td { text-align: left; padding: 6px 8px; border-bottom: 1px solid #f0f0f0; }
  th { color: #6b7280; font-weight: 600; }
  td.num, th.num { text-align: right; }
  .langs { color: #374151; }
  .footer { color: #9ca3af; font-size: 12px; margin-top: 24px; text-align: center; }
  .empty { background: #fff; border: 1px solid #e5e7eb; border-radius: 8px;
           padding: 24px; text-align: center; color: #6b7280; }
</style>
</head>
<body>
<div class="wrap">
  <h1>{{ report.app_name }} <span class="q-test">({{ report.domain }})</span></h1>
  <div class="meta">
    User-reported quiz issues &middot; last {{ report.days }} days
    ({{ report.date_from }} → {{ report.date_to }}) &middot;
    generated {{ report.generated_at }}
  </div>

  {% if report.is_empty %}
  <div class="empty">No reported issues in this window.</div>
  {% else %}
  <div class="summary">
    <b>{{ report.report_count }}</b> reports across
    <b>{{ report.questions | length }}</b> questions
    {%- if report.reset_count %} &middot; {{ report.reset_count }} resets{% endif %}
    {%- if report.unresolved_question_ids %}
    &middot; {{ report.unresolved_question_ids | length }} unresolved question id(s)
    {%- endif %}
    <div style="color:#6b7280;font-size:12px;margin-top:6px;">
      A report is one user in one session; a single report may flag several
      issue types, so per-issue counts can exceed the report count.
    </div>
  </div>

  {% for q in report.questions %}
  <div class="q {% if not q.resolved %}unresolved{% endif %}">
    <div class="q-head">
      <div>
        <p class="q-title">Q{{ q.question_id }}
          {%- if q.test_title %} <span class="q-test">· {{ q.test_title }}</span>{% endif %}
        </p>
      </div>
      <div>
        <span class="badge">{{ q.report_count }} report{{ '' if q.report_count == 1 else 's' }}</span>
        {%- if q.reset_count %}<span class="badge reset">{{ q.reset_count }} reset</span>{% endif %}
      </div>
    </div>

    <div class="q-text">{{ q.question_text }}</div>

    {% if q.image %}
      {% if q.image_url %}<img class="q-img" src="{{ q.image_url }}" alt="question image">
      {% else %}<div class="img-name">🖼 image: {{ q.image }}</div>{% endif %}
    {% endif %}

    {% if q.answers %}
    <ul class="answers">
      {% for a in q.answers %}
      <li class="{{ 'right' if a.is_right else '' }}">{{ a.text }}{{ ' ✓' if a.is_right else '' }}</li>
      {% endfor %}
    </ul>
    {% endif %}

    <table>
      <thead>
        <tr>
          <th>Issue</th>
          <th class="num">Reports</th>
          <th class="num">Resets</th>
          <th>Languages</th>
        </tr>
      </thead>
      <tbody>
        {% for issue in q.issues %}
        <tr>
          <td>{{ issue.category }}</td>
          <td class="num">{{ issue.count }}</td>
          <td class="num">{{ issue.reset_count or '' }}</td>
          <td class="langs">
            {%- for lang, n in issue.by_language | dictsort(by='value', reverse=true) -%}
              {{ lang }} ({{ n }}){{ ', ' if not loop.last else '' }}
            {%- endfor -%}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endfor %}
  {% endif %}

  <div class="footer">quiz-dataset-report</div>
</div>
</body>
</html>
